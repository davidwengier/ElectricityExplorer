@using System.Globalization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="chart-mouse-navigator">
    <div class="chart-navigator-heading">
        <div>
            <strong>Full history</strong>
            <span>Scroll over the main graph to zoom. Drag it to pan. Drag this highlighted window or its edges.</span>
        </div>
        <button type="button"
                @onclick="ResetAsync"
                disabled="@IsShowingAllData">Reset view</button>
    </div>

    <svg id="@_overviewElementId"
         class="chart-overview"
         viewBox="0 0 1000 90"
         role="img"
         aria-label="Full-history chart navigator"
         preserveAspectRatio="none">
        <defs>
            <clipPath id="@_clipPathId">
                <rect x="0" y="@PlotTop" width="1000" height="@(PlotBottom - PlotTop)" />
            </clipPath>
        </defs>

        <rect class="chart-overview-background"
              x="0"
              y="@PlotTop"
              width="1000"
              height="@(PlotBottom - PlotTop)" />

        <g clip-path="@($"url(#{_clipPathId})")">
            @foreach (var series in Series.Where(item => item.Points.Count > 0))
            {
                <path class="chart-overview-line"
                      d="@PathFor(series.Points)"
                      stroke="@series.Color"
                      stroke-dasharray="@series.DashArray" />
            }
        </g>

        <rect class="chart-overview-shade chart-overview-shade-left"
              x="0"
              y="@PlotTop"
              width="@SelectionX"
              height="@(PlotBottom - PlotTop)" />
        <rect class="chart-overview-shade chart-overview-shade-right"
              x="@(SelectionX + SelectionWidth)"
              y="@PlotTop"
              width="@(1000 - SelectionX - SelectionWidth)"
              height="@(PlotBottom - PlotTop)" />
        <rect class="chart-overview-selection"
              x="@SelectionX"
              y="@PlotTop"
              width="@SelectionWidth"
              height="@(PlotBottom - PlotTop)" />
        <line class="chart-overview-handle chart-overview-handle-start"
              x1="@SelectionX"
              x2="@SelectionX"
              y1="@PlotTop"
              y2="@PlotBottom" />
        <line class="chart-overview-handle chart-overview-handle-end"
              x1="@(SelectionX + SelectionWidth)"
              x2="@(SelectionX + SelectionWidth)"
              y1="@PlotTop"
              y2="@PlotBottom" />
        <rect class="chart-overview-interaction"
              x="0"
              y="0"
              width="1000"
              height="90" />
    </svg>
</div>

@code {
    private const double PlotTop = 8;
    private const double PlotBottom = 82;

    [Parameter, EditorRequired]
    public string MainChartId { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IReadOnlyList<ChartSeries> Series { get; set; } = [];

    [Parameter, EditorRequired]
    public ChartViewport FullViewport { get; set; }

    [Parameter, EditorRequired]
    public ChartViewport ViewViewport { get; set; }

    [Parameter]
    public double MinimumRange { get; set; }

    [Parameter]
    public EventCallback<ChartViewport> ViewViewportChanged { get; set; }

    private readonly string _overviewElementId = $"chart-overview-{Guid.NewGuid():N}";
    private readonly string _clipPathId = $"chart-overview-clip-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<ChartMouseNavigator>? _selfReference;
    private double _minimumY;
    private double _maximumY;

    private bool IsShowingAllData =>
        ChartViewportMath.AreEqual(ViewViewport, FullViewport);

    private double SelectionX => ViewStartRatio * 1000d;

    private double SelectionWidth =>
        Math.Max(1, (ViewEndRatio - ViewStartRatio) * 1000d);

    private double ViewStartRatio =>
        FullViewport.Range <= 0
            ? 0
            : Math.Clamp(
                (ViewViewport.Minimum - FullViewport.Minimum) / FullViewport.Range,
                0,
                1);

    private double ViewEndRatio =>
        FullViewport.Range <= 0
            ? 1
            : Math.Clamp(
                (ViewViewport.Maximum - FullViewport.Minimum) / FullViewport.Range,
                0,
                1);

    private double MinimumSpanRatio =>
        FullViewport.Range <= 0
            ? 1
            : Math.Clamp(MinimumRange / FullViewport.Range, 0.0001, 1);

    protected override void OnParametersSet()
    {
        var points = Series
            .SelectMany(series => series.Points)
            .ToArray();
        if (points.Length == 0)
        {
            _minimumY = 0;
            _maximumY = 1;
            return;
        }

        _minimumY = points.Min(point => point.Y);
        _maximumY = points.Max(point => point.Y);
        if (Math.Abs(_maximumY - _minimumY) < 0.000001)
        {
            _maximumY = _minimumY + 1;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/ElectricityExplorer.UI/js/chartNavigator.js");
        _selfReference ??= DotNetObjectReference.Create(this);

        await _module.InvokeVoidAsync(
            "connect",
            MainChartId,
            _overviewElementId,
            _selfReference,
            ViewStartRatio,
            ViewEndRatio,
            MinimumSpanRatio);
    }

    [JSInvokable]
    public Task SetNormalizedViewport(double start, double end)
    {
        if (!double.IsFinite(start) || !double.IsFinite(end))
        {
            return Task.CompletedTask;
        }

        start = Math.Clamp(start, 0, 1);
        end = Math.Clamp(end, 0, 1);
        if (end < start)
        {
            (start, end) = (end, start);
        }

        var span = end - start;
        if (span < MinimumSpanRatio)
        {
            var centre = (start + end) / 2d;
            start = centre - MinimumSpanRatio / 2d;
            end = centre + MinimumSpanRatio / 2d;

            if (start < 0)
            {
                end -= start;
                start = 0;
            }

            if (end > 1)
            {
                start -= end - 1;
                end = 1;
            }
        }

        return ViewViewportChanged.InvokeAsync(new ChartViewport(
            FullViewport.Minimum + FullViewport.Range * start,
            FullViewport.Minimum + FullViewport.Range * end));
    }

    private Task ResetAsync() =>
        ViewViewportChanged.InvokeAsync(FullViewport);

    private string PathFor(IReadOnlyList<ChartPoint> points) =>
        string.Join(
            " ",
            points.Select((point, index) =>
                string.Create(
                    CultureInfo.InvariantCulture,
                    $"{(index == 0 ? "M" : "L")} {X(point.X):0.##} {Y(point.Y):0.##}")));

    private double X(double value) =>
        FullViewport.Range <= 0
            ? 0
            : (value - FullViewport.Minimum) / FullViewport.Range * 1000d;

    private double Y(double value) =>
        PlotBottom
        - (value - _minimumY)
        / (_maximumY - _minimumY)
        * (PlotBottom - PlotTop);

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("disconnect", _overviewElementId);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _selfReference?.Dispose();
    }
}
